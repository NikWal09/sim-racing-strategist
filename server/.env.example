# Skopiuj ten plik do ".env" i uzupełnij wartości.

# --- Edge-TTS ---
# Domyślny głos (neuronowy, jak na PC). Inne: pl-PL-ZofiaNeural, en-US-AriaNeural...
DEFAULT_VOICE=pl-PL-MarekNeural

# Prosty klucz dostępu — wpisz dowolny losowy ciąg. Aplikacja musi podać ten sam.
# Zostaw puste, by wyłączyć ochronę (NIE zalecane przy serwerze w internecie).
API_KEY=

# --- Discord (opcjonalne; bez tego działa tylko /tts) ---
# Token bota z https://discord.com/developers/applications -> Bot -> Reset Token
DISCORD_TOKEN=
# ID serwera (guild) — włącz Tryb dewelopera w Discordzie, ppm na serwer -> Kopiuj ID
DISCORD_GUILD_ID=
# ID KANAŁU GŁOSOWEGO, na który bot ma wejść — ppm na kanał głosowy -> Kopiuj ID
DISCORD_VOICE_CHANNEL_ID=
